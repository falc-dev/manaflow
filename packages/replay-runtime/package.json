{
  "name": "@manaflow/replay-runtime",
  "version": "0.1.0",
  "description": "Framework-agnostic replay controller and store runtime for Manaflow",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@manaflow/core": "workspace:*",
    "@manaflow/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.3.3",
    "vitest": "1.2.2"
  }
}
