{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manaflow.dev/schemas/format.schema.json",
  "title": "Manaflow Game Format",
  "description": "Schema v1 for Manaflow game format payloads.",
  "markdownDescription": "Versioned format contract for Manaflow (`schemaVersion: 1`). Defines zones, phases, and player slots outside the replay.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "formatId",
    "rulesProfile",
    "players",
    "phases",
    "zones"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "The schema to verify this document against.",
      "examples": [
        "../../../schemas/format.schema.json"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Format schema version.",
      "markdownDescription": "Stable format schema version. Must be `1`.",
      "examples": [
        1
      ]
    },
    "formatId": {
      "type": "string",
      "description": "Stable identifier for the rules/format bundle.",
      "examples": [
        "riftbound-1v1-v1"
      ]
    },
    "name": {
      "type": "string",
      "description": "Human-friendly format name.",
      "examples": [
        "Riftbound 1v1"
      ]
    },
    "rulesProfile": {
      "description": "Rules profile. Can be a string (reference to registered profile) or an inline profile definition.",
      "oneOf": [
        {
          "type": "string",
          "description": "Rules profile id consumed by the replay runtime.",
          "examples": [
            "riftbound-1v1-v1"
          ]
        },
        {
          "$ref": "#/$defs/rulesProfile"
        }
      ]
    },
    "players": {
      "$ref": "#/$defs/players"
    },
    "phases": {
      "type": "array",
      "description": "Ordered list of turn phases used by snapshots (currentPhase).",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "zones": {
      "type": "object",
      "description": "Zone definitions keyed by zone id.",
      "additionalProperties": {
        "$ref": "#/$defs/zoneDefinition"
      }
    },
    "zoneOrder": {
      "type": "array",
      "description": "Optional ordering hint for presenting zones.",
      "items": {
        "type": "string"
      }
    },
    "zoneGroups": {
      "type": "array",
      "description": "Optional zone collections for semantic grouping.",
      "items": {
        "$ref": "#/$defs/zoneGroup"
      }
    },
    "metadata": {
      "type": "object",
      "description": "Extra format-level metadata.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "players": {
      "type": "object",
      "description": "Player slot metadata and ordering.",
      "additionalProperties": false,
      "required": [
        "ids"
      ],
      "properties": {
        "ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "count": {
          "type": "number",
          "description": "Expected player count (should match ids.length)."
        },
        "seatOrder": {
          "type": "array",
          "description": "Optional seat order for turn rotation or layout.",
          "items": {
            "type": "string"
          }
        },
        "labels": {
          "type": "object",
          "description": "Optional human labels per player id.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "phase": {
      "type": "object",
      "description": "Phase definition consumed by snapshots (currentPhase).",
      "markdownDescription": "Turn phase identifier from format.phases (e.g., DRAW, MAIN, COMBAT, END). Used to track game progress.",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Canonical phase identifier.",
          "examples": [
            "DRAW",
            "MAIN",
            "COMBAT",
            "END"
          ]
        },
        "label": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "zoneDefinition": {
      "type": "object",
      "description": "Zone definition shared across all snapshots.",
      "markdownDescription": "Defines a game zone (deck, hand, board, etc.) with ownership, visibility, and layout hints.",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique zone identifier."
        },
        "ownerId": {
          "type": "string",
          "description": "Player id or 'shared' for neutral zones."
        },
        "kind": {
          "type": "string",
          "description": "Semantic zone type.",
          "enum": [
            "deck",
            "hand",
            "board",
            "discard",
            "resource",
            "objective",
            "stack",
            "attachment",
            "limbo",
            "custom"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "owner",
            "hidden"
          ]
        },
        "ordered": {
          "type": "boolean"
        },
        "capacity": {
          "type": "number"
        },
        "label": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "zoneGroup": {
      "type": "object",
      "description": "Semantic grouping for multiple zones.",
      "additionalProperties": false,
      "required": [
        "id",
        "zoneIds"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "zoneIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "rulesProfileZone": {
      "type": "object",
      "description": "Required zone definition for a profile.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Zone id that must exist in the format."
        },
        "ownerId": {
          "type": "string",
          "description": "Expected owner of the zone."
        },
        "kind": {
          "type": "string",
          "description": "Expected zone kind."
        }
      },
      "required": ["id"]
    },
    "rulesProfilePlayers": {
      "type": "object",
      "description": "Player requirements for a profile.",
      "properties": {
        "ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Required player ids."
        },
        "count": {
          "type": "number",
          "description": "Expected player count."
        }
      },
      "required": ["ids"]
    },
    "rulesProfile": {
      "type": "object",
      "description": "Inline rules profile definition embedded in the format.",
      "markdownDescription": "Defines rules requirements (zones, players, actions) directly in the format JSON. Allows self-contained format files without external profile registration.",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique profile identifier.",
          "examples": ["mtg-standard-v1", "pokemon-tcg-v1"]
        },
        "name": {
          "type": "string",
          "description": "Human-friendly profile name."
        },
        "description": {
          "type": "string",
          "description": "Profile description."
        },
        "requiredZones": {
          "type": "array",
          "description": "Zones that must exist in the format.",
          "items": {
            "$ref": "#/$defs/rulesProfileZone"
          }
        },
        "requiredPlayers": {
          "$ref": "#/$defs/rulesProfilePlayers"
        }
      }
    }
  }
}
